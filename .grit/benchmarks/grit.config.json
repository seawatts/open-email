{
  "rules": [
    {
      "category": "style",
      "config": "biome.json",
      "description": "Enforces isOk() over !isErr() and vice versa",
      "name": "no-negated-result-checks",
      "path": ".grit/no-negated-result-checks.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome.json",
      "description": "Prevents IIFEs, suggests helper functions or Effect.pipe()",
      "name": "no-iife",
      "path": ".grit/no-iife.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome.json",
      "description": "Enforces AsyncResult<T> over Promise<Result<T>>",
      "name": "prefer-async-result",
      "path": ".grit/prefer-async-result.grit",
      "severity": "warning"
    },
    {
      "category": "type-safety",
      "config": "biome.json",
      "description": "Enforces satisfies clause on OpenAI schema exports",
      "name": "openai-responses-pattern",
      "path": ".grit/openai-responses-pattern.grit",
      "severity": "warning"
    },
    {
      "category": "naming",
      "config": "biome.json",
      "description": "Enforces 'Schema' suffix on OpenAI/Open prefixed schemas",
      "name": "openai-naming-convention",
      "path": ".grit/openai-naming-convention.grit",
      "severity": "warning"
    },
    {
      "category": "consistency",
      "config": "biome.json",
      "description": "Enforces OpenResponses schemas reference base OpenAIResponses schemas",
      "name": "openresponses-pattern",
      "path": ".grit/openresponses-pattern.grit",
      "severity": "info"
    },
    {
      "category": "correctness",
      "config": "biome.json",
      "description": "Enforces safeRace() over Promise.race() to prevent memory leaks",
      "name": "no-promise-race",
      "path": ".grit/no-promise-race.grit",
      "severity": "error"
    },
    {
      "category": "maintainability",
      "config": "biome.json",
      "description": "Enforces object destructuring for 4+ parameters",
      "name": "use-named-arguments",
      "path": ".grit/use-named-arguments.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome.json",
      "description": "Enforces .nullish() over .nullable().optional()",
      "name": "prefer-nullish-over-optional-nullable",
      "path": ".grit/prefer-nullish-over-optional-nullable.grit",
      "severity": "warning"
    },
    {
      "category": "test-quality",
      "config": "biome.json",
      "description": "Enforces assertOk()/assertErr() over expect(isOk()).toBe(true)",
      "name": "prefer-assert-over-expect-result",
      "path": ".grit/prefer-assert-over-expect-result.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Suggests wrap() over try/catch for consistent error handling",
      "name": "prefer-wrap-over-try-catch",
      "path": ".grit/prefer-wrap-over-try-catch.grit",
      "severity": "info"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Suggests runIfCalledAsScript for zx scripts",
      "name": "prefer-run-if-called-as-script",
      "path": ".grit/prefer-run-if-called-as-script.grit",
      "severity": "info"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Prefer className with Tailwind over inline style attributes",
      "name": "prefer-classname-over-style",
      "path": ".grit/prefer-classname-over-style.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Prefer React components over render helper functions",
      "name": "prefer-component-over-render-helper",
      "path": ".grit/prefer-component-over-render-helper.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Prefer ValueOf<typeof X> over (typeof X)[number]",
      "name": "prefer-valueof-helper",
      "path": ".grit/prefer-valueof-helper.grit",
      "severity": "warning"
    },
    {
      "category": "style",
      "config": "biome-incremental.json",
      "description": "Avoid template strings in logging helpers, use constant strings with context objects",
      "name": "no-template-string-in-logs",
      "path": ".grit/no-template-string-in-logs.grit",
      "severity": "warning"
    }
  ]
}
