{
  "dependencies": {
    "@seawatts/id": "workspace:*",
    "@seawatts/logger": "workspace:*",
    "@seawatts/zustand": "workspace:*",
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "catalog:",
    "@vercel/postgres": "0.10.0",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-seed": "0.3.1",
    "drizzle-zod": "catalog:",
    "lodash-es": "4.17.23",
    "next": "catalog:",
    "postgres": "3.4.8",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.8.3",
    "@seawatts/tsconfig": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@testing-library/jest-dom": "6.9.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.4.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "chokidar": "5.0.0",
    "drizzle-kit": "0.31.9",
    "supabase": "2.77.1",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "zx": "^8.8.5"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./supabase/cli": "./src/supabase/cli.ts",
    "./supabase/client": "./src/supabase/client-exports.ts",
    "./supabase/create-channel": "./src/supabase/create-channel.ts",
    "./supabase/get-realtime-record": "./src/supabase/get-realtime-record.ts",
    "./supabase/rcs": "./src/supabase/server.rcs.ts",
    "./supabase/server": "./src/supabase/server-exports.ts",
    "./supabase/storage": "./src/supabase/storage.ts",
    "./supabase/types": "./src/supabase/types.generated.ts"
  },
  "license": "MIT",
  "name": "@seawatts/db",
  "private": true,
  "scripts": {
    "build.skip": "bun run gen-supabase-types",
    "clean": "git clean -xdf .turbo node_modules dist",
    "create-supabase-policies": "tsx scripts/create-supabase-policies.ts",
    "dev": "tsx ./scripts/watch.ts",
    "enable-supabase-realtime": "tsx scripts/enable-supabase-realtime.ts",
    "gen-migration": "infisical run -- drizzle-kit generate",
    "gen-supabase-types": "tsx ./scripts/generate-supabase-types.ts",
    "migrate": "infisical run -- tsx scripts/ensure-schema.ts && infisical run -- drizzle-kit migrate && infisical run -- bun gen-supabase-types && infisical run -- bun create-supabase-policies && infisical run -- bun enable-supabase-realtime",
    "migrate:ci": "tsx scripts/ensure-schema.ts && drizzle-kit migrate && bun gen-supabase-types && bun create-supabase-policies && bun enable-supabase-realtime",
    "push": "infisical run -- drizzle-kit push && bun gen-supabase-types && bun create-supabase-policies && bun enable-supabase-realtime",
    "push:ci": "drizzle-kit push && bun gen-supabase-types && bun create-supabase-policies && bun enable-supabase-realtime",
    "seed": "infisical run -- tsx src/seed.ts",
    "studio": "infisical run -- drizzle-kit studio",
    "test:integ": "bun test --test=integ",
    "test:unit": "bun test --test=unit",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "type": "module",
  "version": "0.1.0"
}
